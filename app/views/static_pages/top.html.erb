<div class="w-full min-h-screen relative" style="background-image: url('<%= image_url('miyagitop.jpeg') %>'); background-size: cover; background-position: center;">
  <!-- 黒い半透明のオーバーレイ（オプション） -->
  <!-- コンテンツ全体 -->
  <div class="relative z-10">
    <!-- トップセクション -->
    <div class="text-emerald-900 text-center py-16">
      <h1 class="text-5xl font-bold mb-4">宮城のタイピング</h1>
      <p class="text-xl mb-8">タイピングで宮城の魅力を発見しよう！</p>
      <%= link_to 'スタート', selections_path, class: 'bg-emerald-800 text-white px-8 py-3 rounded-full font-bold hover:bg-emerald-600 transition' %>
    </div>

    <!-- カードのセクション -->
    <div class="container mx-auto py-16 px-4">
      <h2 class="text-3xl font-bold text-center mb-12 text-emerald-900">このアプリについて</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- カード1 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="text-xl font-bold mb-4">楽しく学べる</h3>
          <p class="text-gray-600">タイピングを通じて宮城県の魅力を楽しく学べます。</p>
        </div>

        <!-- カード2 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="text-xl font-bold mb-4">スキルアップ</h3>
          <p class="text-gray-600">タイピングスキルを向上させながら、地域の知識も深まります。</p>
        </div>

        <!-- カード3 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="text-xl font-bold mb-4">記録を残せる</h3>
          <p class="text-gray-600">自分の成長を記録として残すことができます。</p>
        </div>
      </div>
    </div>
  </div>
</div>
